{
  "name": "ledgerly",
  "version": "1.1.0",
  "description": "프리랜서 세금 계산 및 재무 관리 앱",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.ledgerly.app",
    "productName": "Ledgerly",
    "win": {
      "target": "nsis",
      "icon": "icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
